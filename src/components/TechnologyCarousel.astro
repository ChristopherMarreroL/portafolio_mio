---
type Lang = "es" | "en";
type Tech = { name: string; icon: string; category?: string };

const { tech, lang = "en" } = Astro.props as { tech: Tech[]; lang?: Lang };

const labels = {
  title: lang === "es" ? "Tecnologias" : "Technologies",
  select: lang === "es" ? "Seleccionar tecnologia" : "Select technology",
  help: lang === "es" ? "Usa las flechas del teclado, toca o desliza para navegar" : "Use keyboard arrows, tap, or swipe to navigate",
};
---

<section data-tech-carousel class="mx-auto mt-10 max-w-4xl overflow-x-clip" aria-labelledby="tech-carousel-title">
  <div class="flex items-center justify-between gap-4">
    <p id="tech-carousel-title" class="text-sm font-medium text-slate-700 dark:text-slate-200">
      {labels.title}
    </p>
    <p class="hidden text-right text-xs text-slate-500 dark:text-slate-400 sm:block">{labels.help}</p>
  </div>

  <div
    data-tech-stage
    class="relative mx-auto mt-4 h-[280px] w-full max-w-full overflow-x-clip overflow-y-visible rounded-[2rem] px-0 py-8 outline-none before:pointer-events-none before:absolute before:left-1/2 before:top-1/2 before:h-44 before:w-64 before:-translate-x-1/2 before:-translate-y-1/2 before:rounded-full before:bg-sky-400/12 before:blur-3xl focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-sky-300/45 dark:before:bg-cyan-400/10 dark:focus-visible:outline-cyan-300/35 sm:h-[350px] sm:overflow-visible sm:before:h-52 sm:before:w-96"
    tabindex="0"
    role="region"
    aria-label={labels.title}
  >
    <div data-tech-track class="relative mx-auto h-full w-full max-w-4xl [perspective:1500px] [transform-style:preserve-3d]">
      {tech.map((item, index) => (
        <button
          data-tech-item
          data-index={index}
          data-name={item.name}
          data-category={item.category ?? ""}
          type="button"
          class="absolute left-1/2 top-1/2 flex h-28 w-28 -translate-x-1/2 -translate-y-1/2 cursor-pointer touch-manipulation flex-col items-center justify-center rounded-[1.5rem] border border-white/50 bg-white/80 p-4 text-center shadow-[0_20px_70px_rgba(15,23,42,0.10)] backdrop-blur-xl transition-colors hover:bg-white focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-300/45 dark:border-slate-800/60 dark:bg-slate-950/80 dark:shadow-[0_22px_80px_rgba(0,0,0,0.32)] dark:hover:bg-slate-900/95 dark:focus-visible:ring-cyan-300/35 sm:h-40 sm:w-40 sm:rounded-[1.75rem] sm:p-5 lg:h-44 lg:w-44"
          aria-label={`${labels.select}: ${item.name}`}
        >
          <img data-tech-icon src={item.icon} alt="" class="h-18 w-18 object-contain sm:h-24 sm:w-24 lg:h-28 lg:w-28" loading="lazy" />
        </button>
      ))}
    </div>
  </div>

  <div class="mt-4 text-center">
    <p data-tech-active-name class="text-xl font-semibold tracking-tight text-slate-900 dark:text-slate-100">
      {tech[0]?.name}
    </p>
    <p data-tech-active-category class="mt-1 text-sm text-slate-500 dark:text-slate-400">
      {tech[0]?.category}
    </p>
  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const root = document.querySelector<HTMLElement>("[data-tech-carousel]");
  const stage = root?.querySelector<HTMLElement>("[data-tech-stage]");
  const items = Array.from(root?.querySelectorAll<HTMLElement>("[data-tech-item]") ?? []);
  const icons = Array.from(root?.querySelectorAll<HTMLElement>("[data-tech-icon]") ?? []);
  const activeName = root?.querySelector<HTMLElement>("[data-tech-active-name]");
  const activeCategory = root?.querySelector<HTMLElement>("[data-tech-active-category]");
  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const isDesktop = window.matchMedia("(min-width: 768px)").matches;

  const techNames = items.map((item) => item.dataset.name ?? "");
  const techCategories = items.map((item) => item.dataset.category ?? "");
  let activeIndex = 0;
  let startX = 0;

  const config = {
    desktopSpacing: 260,
    mobileSpacing: 88,
    depth: prefersReducedMotion ? 0 : 155,
    rotateY: prefersReducedMotion ? 0 : 58,
    visibleSideItems: isDesktop ? 2 : 1,
    duration: prefersReducedMotion ? 0 : 0.62,
    activeScale: isDesktop ? 1.26 : 1.12,
    sideHoverScale: isDesktop ? 1.18 : 1.05,
    activeHoverScale: isDesktop ? 1.34 : 1.14,
  };

  function shortestOffset(index: number) {
    const total = items.length;
    let offset = index - activeIndex;
    if (offset > total / 2) offset -= total;
    if (offset < -total / 2) offset += total;
    return offset;
  }

  function renderCarousel() {
    const spacing = isDesktop ? config.desktopSpacing : config.mobileSpacing;

    items.forEach((item, index) => {
      const offset = shortestOffset(index);
      const abs = Math.abs(offset);
      const isActive = offset === 0;
      const hidden = abs > config.visibleSideItems;
      const x = offset * spacing;
      const z = -abs * config.depth;
      const rotateY = offset === 0 ? 0 : offset > 0 ? -config.rotateY : config.rotateY;
      const rotateZ = offset === 0 ? 0 : offset > 0 ? -2 : 2;
      const y = isActive ? (isDesktop ? -10 : -4) : abs * (isDesktop ? 12 : 6);
      const scale = isActive ? config.activeScale : Math.max(0.68, 0.9 - abs * 0.08);
      const opacity = hidden ? 0 : isActive ? 1 : Math.max(0.32, 0.72 - abs * 0.13);
      const shadow = isActive
        ? "0 34px 100px rgba(14, 165, 233, 0.24), 0 18px 48px rgba(15, 23, 42, 0.14)"
        : "0 18px 52px rgba(15, 23, 42, 0.12)";

      item.dataset.active = String(isActive);
      item.setAttribute("aria-current", isActive ? "true" : "false");
      item.tabIndex = hidden ? -1 : 0;

      gsap.to(item, {
        xPercent: -50,
        yPercent: -50,
        x,
        y,
        z,
        rotateY,
        rotateZ,
        scale,
        opacity,
        boxShadow: shadow,
        filter: hidden ? "blur(2px)" : isActive ? "blur(0px) saturate(1.08)" : "blur(0px) saturate(0.9)",
        transformOrigin: "50% 50%",
        duration: config.duration,
        ease: "power3.out",
        zIndex: 100 - abs,
        pointerEvents: hidden ? "none" : "auto",
        overwrite: "auto",
      });

      gsap.to(icons[index], {
        scale: isActive ? 1.14 : 0.92,
        opacity: isActive ? 1 : 0.78,
        duration: config.duration,
        ease: "power3.out",
      });
    });

    if (activeName) activeName.textContent = techNames[activeIndex] ?? "";
    if (activeCategory) activeCategory.textContent = techCategories[activeIndex] ?? "";
  }

  function goTo(index: number) {
    activeIndex = (index + items.length) % items.length;
    renderCarousel();
  }

  items.forEach((item, index) => {
    item.addEventListener("click", (event) => {
      event.stopPropagation();
      goTo(index);
    });
    item.addEventListener("pointerenter", () => {
      if (prefersReducedMotion || !isDesktop) return;
      const isActive = item.dataset.active === "true";
      const boost = isActive ? config.activeHoverScale : config.sideHoverScale;
      gsap.to(item, {
        xPercent: -50,
        yPercent: -50,
        scale: boost,
        y: isActive ? -18 : -14,
        opacity: 1,
        zIndex: 200,
        boxShadow: "0 42px 120px rgba(14, 165, 233, 0.34), 0 24px 60px rgba(15, 23, 42, 0.22)",
        filter: "blur(0px) saturate(1.14)",
        duration: 0.3,
        ease: "power3.out",
        overwrite: "auto",
      });

      const icon = item.querySelector<HTMLElement>("[data-tech-icon]");
      if (icon) gsap.to(icon, { scale: isActive ? 1.18 : 1.12, duration: 0.3, ease: "power3.out", overwrite: "auto" });
    });
    item.addEventListener("pointerleave", renderCarousel);
  });

  stage?.addEventListener("click", (event) => {
    if (!isDesktop) return;

    const rect = stage.getBoundingClientRect();
    const relativeX = event.clientX - rect.left;
    const centerX = rect.width / 2;
    const deadZone = 70;

    if (relativeX > centerX + deadZone) goTo(activeIndex + 1);
    if (relativeX < centerX - deadZone) goTo(activeIndex - 1);
  });

  stage?.addEventListener("keydown", (event) => {
    if (event.key === "ArrowLeft") {
      event.preventDefault();
      goTo(activeIndex - 1);
    }

    if (event.key === "ArrowRight") {
      event.preventDefault();
      goTo(activeIndex + 1);
    }
  });

  stage?.addEventListener("touchstart", (event) => {
    startX = event.touches[0]?.clientX ?? 0;
  }, { passive: true });

  stage?.addEventListener("touchend", (event) => {
    const endX = event.changedTouches[0]?.clientX ?? startX;
    const delta = endX - startX;
    if (Math.abs(delta) < 35) return;
    goTo(delta > 0 ? activeIndex - 1 : activeIndex + 1);
  }, { passive: true });

  if (!prefersReducedMotion && root) {
    gsap.fromTo(
      root,
      { opacity: 0, y: 30, scale: 0.98 },
      {
        opacity: 1,
        y: 0,
        scale: 1,
        duration: 0.75,
        ease: "power3.out",
        scrollTrigger: {
          trigger: root,
          start: "top 85%",
          once: true,
        },
      },
    );
  }

  renderCarousel();
</script>
