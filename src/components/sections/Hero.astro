---
import type { Lang } from "../../i18n/translations";
import { t } from "../../i18n/translations";
import TechnologyCarousel from "../TechnologyCarousel.astro";

const { lang = "en" } = Astro.props as { lang?: Lang };
const tr = t[lang];

const tech = [
  { name: "C#", icon: "/tech/csharp.svg", category: "Backend" },
  { name: ".NET", icon: "/tech/dotnet.svg", category: "Backend" },
  { name: "SQL Server", icon: "/tech/sqlserver.svg", category: "Database" },
  { name: "JavaScript", icon: "/tech/javascript.svg", category: "Frontend" },
  { name: "TypeScript", icon: "/tech/typescript.svg", category: "Frontend" },
  { name: "HTML", icon: "/tech/html.svg", category: "Markup" },
  { name: "CSS", icon: "/tech/css.svg", category: "Styles" },
  { name: "Tailwind", icon: "/tech/tailwind.svg", category: "Styles" },
  { name: "React", icon: "/tech/react.svg", category: "UI" },
  { name: "Astro", icon: "/tech/astro.svg", category: "Framework" },
  { name: "Flutter", icon: "/tech/flutter.svg", category: "Mobile" }
];

const name = "Christopher";
---

<section class="py-10">
  <p data-animate="hero-greeting" class="mt-4 max-w-2xl text-base text-slate-600 dark:text-slate-300">{tr.hero.hi}</p>

  <h1 data-animate="hero-name" class="mt-2 overflow-hidden text-4xl font-bold tracking-tight sm:text-5xl" aria-label={name}>
    <span class="sr-only">{name}</span>
    <span data-animate="hero-name-word" aria-hidden="true" class="inline-flex">
      {name.split("").map((letter) => (
        <span data-animate="hero-letter" class="inline-block will-change-transform">
          {letter}
        </span>
      ))}
    </span>
  </h1>

  <p data-animate="hero-description" class="mt-4 max-w-2xl text-base text-slate-600 dark:text-slate-300">
    {tr.hero.subtitle}
  </p>

  <TechnologyCarousel tech={tech} lang={lang} />
</section>

<script>
  import { gsap } from "gsap";

  const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (!prefersReducedMotion) {
    const greeting = document.querySelector('[data-animate="hero-greeting"]');
    const name = document.querySelector('[data-animate="hero-name"]');
    const letters = gsap.utils.toArray<HTMLElement>('[data-animate="hero-letter"]');
    const description = document.querySelector('[data-animate="hero-description"]');

    const timeline = gsap.timeline({ defaults: { ease: "power3.out" } });

    timeline
      .fromTo(greeting, { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 0.65 })
      .fromTo(name, { opacity: 0, scale: 0.9, filter: "blur(10px)" }, { opacity: 1, scale: 1, filter: "blur(0px)", duration: 0.42 }, "-=0.15")
      .fromTo(letters, { opacity: 0, y: 44, rotateX: -55 }, { opacity: 1, y: 0, rotateX: 0, duration: 0.7, stagger: 0.035 }, "-=0.18")
      .to(name, { textShadow: "0 0 28px rgba(14, 165, 233, 0.22)", duration: 0.22 }, "-=0.28")
      .to(name, { textShadow: "0 0 0 rgba(14, 165, 233, 0)", duration: 0.5 })
      .fromTo(description, { opacity: 0, y: 18 }, { opacity: 1, y: 0, duration: 0.65 }, "-=0.45");
  }
</script>
