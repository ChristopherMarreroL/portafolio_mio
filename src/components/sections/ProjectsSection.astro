---
import ProjectCard from "../ProjectCard.astro";
import { supabase } from "../../lib/supabase";
import type { Project as DbProject } from "../../types/content";

type Lang = "es" | "en";
type I18nText = { es: string; en: string };

type Project = {
  title: I18nText;
  description: I18nText;
  tech?: string[];
  link?: string;
  github?: string;
  image?: string;
  gallery?: string[];
};

const { lang = "en" } = Astro.props as { lang?: Lang };

const sectionTitle = lang === "es" ? "Proyectos" : "Projects";

const { data, error } = await supabase
  .from("projects")
  .select("title_es,title_en,description_es,description_en,image_url,project_url,github_url,tools")
  .eq("published", true)
  .order("sort_order", { ascending: true })
  .order("created_at", { ascending: false });

const projects = ((data ?? []) as DbProject[]).map((p) => ({
  title: { es: p.title_es, en: p.title_en || p.title_es },
  description: { es: p.description_es, en: p.description_en || p.description_es },
  tech: p.tools ?? [],
  link: p.project_url ?? "",
  github: p.github_url ?? "",
  image: p.image_url ?? "",
  gallery: [],
})) satisfies Project[];
---

<section id="projects" class="py-10">
  <div class="flex items-end justify-between gap-4">
    <h2 class="text-2xl font-semibold tracking-tight">
      {sectionTitle}
    </h2>

    <p class="mt-4 max-w-2xl text-base text-slate-600 dark:text-slate-300">
      {projects.length} total
    </p>
  </div>

  {error && (
    <p class="mt-4 text-sm text-red-500">
      {lang === "es" ? "No se pudieron cargar los proyectos." : "Projects could not be loaded."}
    </p>
  )}

  <div class="mt-6 grid gap-4 sm:grid-cols-2">
    {projects.map((p) => <ProjectCard project={p} lang={lang} />)}
  </div>
</section>
