---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Nuevo Proyecto">
  <h1 class="text-3xl font-semibold tracking-tight">Nuevo proyecto</h1>

<form id="project-form" class="mt-6 grid gap-4 rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-950">
  <div class="grid gap-4 md:grid-cols-2">
    <label class="text-sm">Titulo ES<input id="title_es" required class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
    <label class="text-sm">Titulo EN<input id="title_en" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
  </div>
  <label class="text-sm">Slug<input id="slug" required class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
  <div class="grid gap-4 md:grid-cols-2">
    <label class="text-sm">Descripcion ES<textarea id="description_es" required rows="5" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950"></textarea></label>
    <label class="text-sm">Descripcion EN<textarea id="description_en" rows="5" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950"></textarea></label>
  </div>
  <label class="text-sm">Herramientas, separadas por coma<input id="tools" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
  <div class="grid gap-4 md:grid-cols-2">
    <label class="text-sm">URL del proyecto<input id="project_url" type="url" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
    <label class="text-sm">URL de GitHub<input id="github_url" type="url" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
  </div>
  <div class="grid gap-4 md:grid-cols-2">
    <div class="text-sm">
      <span>Imagen</span>
      <div class="mt-1 flex flex-wrap items-center gap-3 rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950">
        <label for="image_file" class="cursor-pointer rounded-lg bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:opacity-90 dark:bg-white dark:text-slate-900">Elegir archivo</label>
        <span id="image_file_name" class="text-sm text-slate-500 dark:text-slate-400">Ningun archivo seleccionado</span>
        <input id="image_file" type="file" accept="image/*" class="sr-only" />
      </div>
    </div>
    <label class="text-sm">URL de imagen<input id="image_url" type="url" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
  </div>
  <div class="grid gap-4 md:grid-cols-3">
    <label class="text-sm">Orden<input id="sort_order" type="number" value="0" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
    <label class="mt-7 flex items-center gap-2 text-sm"><input id="featured" type="checkbox" /> Destacado</label>
    <label class="mt-7 flex items-center gap-2 text-sm"><input id="published" type="checkbox" /> Publicado</label>
  </div>
  <div class="flex flex-wrap gap-3">
    <button class="rounded-lg bg-slate-900 px-4 py-2 text-white dark:bg-white dark:text-slate-900" type="submit">Guardar</button>
    <a class="rounded-lg border border-slate-200 px-4 py-2 dark:border-slate-800" href="/admin/projects">Cancelar</a>
  </div>
  <p id="project-message" class="text-sm"></p>
</form>

<script>
  import { supabase } from "../../../lib/supabase";
  import { bindFileName, checkedValue, inputValue, parseList, showMessage, slugify, uploadImage } from "../../../lib/admin";

  bindFileName("image_file", "image_file_name");

  const title = document.getElementById("title_es") as HTMLInputElement | null;
  const slug = document.getElementById("slug") as HTMLInputElement | null;
  title?.addEventListener("input", () => {
    if (slug && !slug.value) slug.value = slugify(title.value);
  });

  document.getElementById("project-form")?.addEventListener("submit", async (event) => {
    event.preventDefault();
    showMessage("project-message", "Guardando...");
    try {
      const uploadedUrl = await uploadImage("image_file", "projects");
      const { error } = await supabase.from("projects").insert({
        title_es: inputValue("title_es"),
        title_en: inputValue("title_en") || null,
        slug: inputValue("slug") || slugify(inputValue("title_es")),
        description_es: inputValue("description_es"),
        description_en: inputValue("description_en") || null,
        tools: parseList(inputValue("tools")),
        image_url: uploadedUrl || inputValue("image_url") || null,
        project_url: inputValue("project_url") || null,
        github_url: inputValue("github_url") || null,
        featured: checkedValue("featured"),
        published: checkedValue("published"),
        sort_order: Number(inputValue("sort_order") || 0),
      });
      if (error) throw error;
      showMessage("project-message", "Proyecto guardado.", "success");
      location.href = "/admin/projects";
    } catch (error) {
      showMessage("project-message", error instanceof Error ? error.message : "Error guardando proyecto.", "error");
    }
  });
</script>
</AdminLayout>
