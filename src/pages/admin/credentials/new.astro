---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Nueva Formacion">
  <h1 class="text-3xl font-semibold tracking-tight">Nueva formacion</h1>
  <form id="credential-form" class="mt-6 grid gap-4 rounded-xl border border-slate-200 bg-white p-5 dark:border-slate-800 dark:bg-slate-950">
    <div class="grid gap-4 md:grid-cols-2">
      <label class="text-sm">Tipo<select id="type" required class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950"><option value="degree">Degree</option><option value="course">Course</option><option value="diploma">Diploma</option><option value="certification">Certification</option><option value="recognition">Recognition</option></select></label>
      <label class="text-sm">Institucion / emisor<input id="issuer" required class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      <label class="text-sm">Titulo ES<input id="title_es" required class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
      <label class="text-sm">Titulo EN<input id="title_en" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
    </div>
    <div class="grid gap-4 md:grid-cols-2">
      <label class="text-sm">Descripcion ES<textarea id="description_es" rows="4" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950"></textarea></label>
      <label class="text-sm">Descripcion EN<textarea id="description_en" rows="4" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950"></textarea></label>
    </div>
    <label class="text-sm">Etiquetas, separadas por coma<input id="tags" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
    <div class="grid gap-4 md:grid-cols-2">
      <div class="text-sm">
        <span>Imagen o preview</span>
        <div class="mt-1 flex flex-wrap items-center gap-3 rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950">
          <label for="image_file" class="cursor-pointer rounded-lg bg-slate-900 px-3 py-2 text-sm font-medium text-white hover:opacity-90 dark:bg-white dark:text-slate-900">Elegir archivo</label>
          <span id="image_file_name" class="text-sm text-slate-500 dark:text-slate-400">Ningun archivo seleccionado</span>
          <input id="image_file" type="file" accept="image/*" class="sr-only" />
        </div>
      </div>
      <label class="text-sm">URL de imagen<input id="image_url" type="url" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
    </div>
    <div class="grid gap-4 md:grid-cols-3">
      <label class="text-sm">Enlace oficial<input id="credential_url" type="url" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
      <label class="text-sm">Fecha de emision<input id="issued_date" type="date" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 [color-scheme:light] dark:border-slate-800 dark:bg-slate-950 dark:[color-scheme:dark]" /></label>
      <label class="text-sm">Orden<input id="sort_order" type="number" value="0" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" /></label>
    </div>
    <label class="flex items-center gap-2 text-sm"><input id="published" type="checkbox" /> Publicado</label>
    <div class="flex flex-wrap gap-3"><button class="rounded-lg bg-slate-900 px-4 py-2 text-white dark:bg-white dark:text-slate-900" type="submit">Guardar</button><a class="rounded-lg border border-slate-200 px-4 py-2 dark:border-slate-800" href="/admin/credentials">Cancelar</a></div>
    <p id="credential-message" class="text-sm"></p>
  </form>

  <script>
    import { supabase } from "../../../lib/supabase";
    import { bindFileName, checkedValue, inputValue, parseList, showMessage, uploadImage } from "../../../lib/admin";
    bindFileName("image_file", "image_file_name");
    document.getElementById("credential-form")?.addEventListener("submit", async (event) => {
      event.preventDefault();
      showMessage("credential-message", "Guardando...");
      try {
        const uploadedUrl = await uploadImage("image_file", "credentials");
        const { error } = await supabase.from("credentials").insert({
          type: inputValue("type"),
          title_es: inputValue("title_es"),
          title_en: inputValue("title_en") || null,
          issuer: inputValue("issuer"),
          issued_date: inputValue("issued_date") || null,
          description_es: inputValue("description_es") || null,
          description_en: inputValue("description_en") || null,
          tags: parseList(inputValue("tags")),
          image_url: uploadedUrl || inputValue("image_url") || null,
          credential_url: inputValue("credential_url") || null,
          published: checkedValue("published"),
          sort_order: Number(inputValue("sort_order") || 0),
        });
        if (error) throw error;
        location.href = "/admin/credentials";
      } catch (error) {
        showMessage("credential-message", error instanceof Error ? error.message : "Error guardando formacion.", "error");
      }
    });
  </script>
</AdminLayout>
