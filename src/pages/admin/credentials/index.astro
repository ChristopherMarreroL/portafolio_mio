---
import AdminLayout from "../../../layouts/AdminLayout.astro";
---

<AdminLayout title="Admin Formacion">
  <div class="flex flex-wrap items-end justify-between gap-4">
    <div>
      <h1 class="text-3xl font-semibold tracking-tight">Formacion</h1>
      <p class="mt-2 text-slate-500 dark:text-slate-400">Cursos, certificaciones, diplomas, reconocimientos y estudios.</p>
    </div>
    <a class="rounded-lg bg-slate-900 px-4 py-2 text-white dark:bg-white dark:text-slate-900" href="/admin/credentials/new">Nueva formacion</a>
  </div>

  <div class="mt-6 flex flex-wrap gap-2">
    <button class="filter rounded-lg border border-slate-200 px-3 py-2 text-sm dark:border-slate-800" data-type="">Todas</button>
    <button class="filter rounded-lg border border-slate-200 px-3 py-2 text-sm dark:border-slate-800" data-type="degree">Degree</button>
    <button class="filter rounded-lg border border-slate-200 px-3 py-2 text-sm dark:border-slate-800" data-type="course">Course</button>
    <button class="filter rounded-lg border border-slate-200 px-3 py-2 text-sm dark:border-slate-800" data-type="diploma">Diploma</button>
    <button class="filter rounded-lg border border-slate-200 px-3 py-2 text-sm dark:border-slate-800" data-type="certification">Certification</button>
    <button class="filter rounded-lg border border-slate-200 px-3 py-2 text-sm dark:border-slate-800" data-type="recognition">Recognition</button>
  </div>

  <p id="credentials-message" class="mt-6 text-sm text-slate-500 dark:text-slate-400">Cargando formacion...</p>
  <div id="credentials-list" class="mt-6 overflow-x-auto rounded-xl border border-slate-200 dark:border-slate-800"></div>

  <script>
    import { supabase } from "../../../lib/supabase";
    import type { Credential } from "../../../types/content";

    const list = document.getElementById("credentials-list");
    const message = document.getElementById("credentials-message");
    let activeType = "";

    function setMessage(text: string, error = false) {
      if (!message) return;
      message.textContent = text;
      message.className = error ? "mt-6 text-sm text-red-500" : "mt-6 text-sm text-slate-500 dark:text-slate-400";
    }

    async function loadCredentials() {
      let query = supabase.from("credentials").select("*").order("sort_order", { ascending: true }).order("issued_date", { ascending: false });
      if (activeType) query = query.eq("type", activeType);
      const { data, error } = await query;
      if (error) return setMessage(error.message, true);

      const credentials = (data ?? []) as Credential[];
      setMessage(`${credentials.length} elementos encontrados.`);
      if (!list) return;
      list.innerHTML = `
        <table class="w-full min-w-[760px] text-left text-sm">
          <thead class="bg-slate-50 text-slate-500 dark:bg-slate-900 dark:text-slate-400">
            <tr><th class="px-4 py-3">Titulo</th><th class="px-4 py-3">Tipo</th><th class="px-4 py-3">Fecha</th><th class="px-4 py-3">Estado</th><th class="px-4 py-3">Acciones</th></tr>
          </thead>
          <tbody>
            ${credentials.map((item) => `
              <tr class="border-t border-slate-200 dark:border-slate-800">
                <td class="px-4 py-3"><strong>${item.title_es}</strong><span class="block text-xs text-slate-500">${item.issuer}</span></td>
                <td class="px-4 py-3">${item.type}</td>
                <td class="px-4 py-3">${item.issued_date ?? ""}</td>
                <td class="px-4 py-3">${item.published ? "Publicado" : "Borrador"}</td>
                <td class="px-4 py-3"><div class="flex flex-wrap gap-2">
                  <a class="rounded-lg border border-slate-200 px-3 py-1 dark:border-slate-800" href="/admin/credentials/edit/${item.id}">Editar</a>
                  <button class="toggle rounded-lg border border-slate-200 px-3 py-1 dark:border-slate-800" data-id="${item.id}" data-published="${item.published}">${item.published ? "Despublicar" : "Publicar"}</button>
                  <button class="delete rounded-lg border border-red-200 px-3 py-1 text-red-500 dark:border-red-900" data-id="${item.id}">Eliminar</button>
                </div></td>
              </tr>`).join("")}
          </tbody>
        </table>`;

      list.querySelectorAll<HTMLButtonElement>(".toggle").forEach((button) => button.addEventListener("click", async () => {
        const { error } = await supabase.from("credentials").update({ published: button.dataset.published !== "true" }).eq("id", button.dataset.id);
        if (error) return setMessage(error.message, true);
        await loadCredentials();
      }));
      list.querySelectorAll<HTMLButtonElement>(".delete").forEach((button) => button.addEventListener("click", async () => {
        if (!confirm("Seguro que quieres eliminar este elemento de formacion?")) return;
        const { error } = await supabase.from("credentials").delete().eq("id", button.dataset.id);
        if (error) return setMessage(error.message, true);
        await loadCredentials();
      }));
    }

    document.querySelectorAll<HTMLButtonElement>(".filter").forEach((button) => button.addEventListener("click", async () => {
      activeType = button.dataset.type ?? "";
      await loadCredentials();
    }));

    await loadCredentials();
  </script>
</AdminLayout>
