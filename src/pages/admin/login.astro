---
import AdminLayout from "../../layouts/AdminLayout.astro";
---

<AdminLayout title="Admin Login" protect={false}>
  <section class="mx-auto max-w-md rounded-2xl border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-950">
    <h1 class="text-2xl font-semibold tracking-tight">Iniciar sesion</h1>
    <p class="mt-2 text-sm text-slate-500 dark:text-slate-400">Accede con el usuario creado en Supabase Auth.</p>

    <form id="login-form" class="mt-6 space-y-4">
      <label class="block text-sm">
        Email
        <input required id="email" type="email" class="mt-1 w-full rounded-lg border border-slate-200 bg-white px-3 py-2 dark:border-slate-800 dark:bg-slate-950" />
      </label>
      <label class="block text-sm">
        Password
        <span class="relative mt-1 block">
          <input required id="password" type="password" class="admin-password-input w-full rounded-lg border border-slate-200 bg-white py-2 pl-3 pr-12 dark:border-slate-800 dark:bg-slate-950" />
          <button
            id="toggle-password"
            type="button"
            class="absolute right-2 top-1/2 inline-flex h-8 w-8 -translate-y-1/2 items-center justify-center rounded-md text-slate-500 transition hover:bg-slate-100 hover:text-slate-900 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-300/60 dark:text-slate-400 dark:hover:bg-slate-900 dark:hover:text-white"
            aria-label="Mostrar contrasena"
            title="Mostrar contrasena"
          >
            <span id="toggle-password-icon" aria-hidden="true">&#128065;</span>
          </button>
        </span>
      </label>
      <button class="w-full rounded-lg bg-slate-900 px-4 py-2 font-medium text-white hover:opacity-90 dark:bg-white dark:text-slate-900" type="submit">Entrar</button>
      <p id="login-message" class="text-sm"></p>
    </form>
  </section>

  <style>
    .admin-password-input::-ms-reveal,
    .admin-password-input::-ms-clear {
      display: none;
    }
  </style>

  <script>
    import { supabase } from "../../lib/supabase";

    const form = document.getElementById("login-form") as HTMLFormElement | null;
    const message = document.getElementById("login-message");
    const passwordInput = document.getElementById("password") as HTMLInputElement | null;
    const togglePassword = document.getElementById("toggle-password") as HTMLButtonElement | null;
    const togglePasswordIcon = document.getElementById("toggle-password-icon");

    togglePassword?.addEventListener("click", () => {
      if (!passwordInput) return;

      const showPassword = passwordInput.type === "password";
      passwordInput.type = showPassword ? "text" : "password";
      togglePassword.setAttribute("aria-label", showPassword ? "Ocultar contrasena" : "Mostrar contrasena");
      togglePassword.setAttribute("title", showPassword ? "Ocultar contrasena" : "Mostrar contrasena");
      if (togglePasswordIcon) togglePasswordIcon.innerHTML = showPassword ? "&#128584;" : "&#128065;";
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (message) message.textContent = "Entrando...";

      const email = (document.getElementById("email") as HTMLInputElement).value;
      const password = (document.getElementById("password") as HTMLInputElement).value;
      const { error } = await supabase.auth.signInWithPassword({ email, password });

      if (error) {
        if (message) {
          message.textContent = error.message;
          message.className = "text-sm text-red-500";
        }
        return;
      }

      sessionStorage.setItem("admin_last_activity_at", String(Date.now()));

      location.href = "/admin/dashboard";
    });
  </script>
</AdminLayout>
